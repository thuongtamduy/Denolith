{
  "name": "denolith",
  "version": "3.0.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run -A --env --watch main.ts",
    "start": "deno run -A --env main.ts",
    "migrate": "deno run -A --env scripts/migrate.ts up",
    "migrate:down": "deno run -A --env scripts/migrate.ts down",
    "migrate:status": "deno run -A --env scripts/migrate.ts status",
    "migrate:reset": "deno run -A --env scripts/migrate.ts reset",
    "migrate:generate": "deno run -A --env scripts/generate-migration.ts",
    "seed": "deno run -A --env scripts/seed.ts",
    "compile": "deno compile -A --env --output ./dist/denolith main.ts",
    "compile:linux": "deno compile -A --env --target x86_64-unknown-linux-gnu --output ./dist/denolith-linux main.ts",
    "test": "deno test -A --env src/",
    "test:watch": "deno test -A --env --watch src/",
    "check": "deno check src/**/*.ts",
    "fmt:check": "deno fmt --check",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@hono/core": "jsr:@hono/hono@4.12.17",
    "@hono/jwt": "jsr:@hono/hono@4.12.17/jwt",
    "@hono/http-status": "jsr:@hono/hono@4.12.17/utils/http-status",
    "@hono/valibot-validator": "jsr:@hono/valibot-validator@0.6.1",
    "@hono/cors": "jsr:@hono/hono@4.12.17/cors",
    "@hono/secure-headers": "jsr:@hono/hono@4.12.17/secure-headers",
    "@hono/cookie": "jsr:@hono/hono@4.12.17/cookie",
    "@db/postgres": "jsr:@db/postgres@0.19.5",
    "@db/redis": "jsr:@db/redis@0.41.1",
    "valibot": "jsr:@valibot/valibot@1.4.0",
    "@hono/hono/deno": "jsr:@hono/hono@4.12.17/deno",
    "@std/assert": "jsr:@std/assert@1.0.0"
  }
}
