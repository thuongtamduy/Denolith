
# 1. DATABASE_URL (Sử dụng cho các truy vấn thông thường của app)
# Kết nối qua cổng 6543 (Transaction Mode của Supavisor).
# Chú ý: Với Prisma bạn bắt buộc phải thêm tham số ?pgbouncer=true&connection_limit=1 
DATABASE_URL="postgresql://postgres.denolith:[REPLACE_DB_PASSWORD]@[PUBLIC_IP_CUA_SERVER]:6543/postgres?pgbouncer=true&connection_limit=1"

# 2. DIRECT_URL (Sử dụng chủ yếu để chạy Migrations - npx prisma db push / prisma migrate)
# Kết nối qua cổng 5432 (Session Mode của Supavisor - hoạt động tương tự như kết nối trực tiếp)
DIRECT_URL="postgresql://postgres.denolith:[REPLACE_DB_PASSWORD]@[PUBLIC_IP_CUA_SERVER]:5432/postgres"

PORT=9999
DENO_ENV=development

# Tạo secret ngẫu nhiên >= 32 ký tự: openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_A_64_CHAR_RANDOM_SECRET_DO_NOT_USE_THIS"

REDIS_URL="redis://localhost:6379"

# ==========================================
# Cấu hình CORS & Security
# ==========================================
FRONTEND_URL="http://localhost:5173"
TRUST_PROXY="false"

# ==========================================
# Cấu hình Gửi Mail SMTP (Optional)
# ==========================================
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS="re_123456789"
# SMTP_FROM="noreply@denolith.dev"

# ==========================================
# Cấu hình Supabase (Storage, Realtime...)
# Chỉ cần nếu dùng Supabase self-hosted hoặc Supabase Cloud
# ==========================================
SUPABASE_URL="http://localhost:8000"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"

# ==========================================
# Cấu hình Lưu Trữ File (Storage)
# Các chế độ hỗ trợ: 'local' | 'supabase' | 's3'
# ==========================================
STORAGE_TYPE="supabase"

# Chỉ cần điền nếu STORAGE_TYPE="s3" (dành cho MinIO hoặc AWS S3)
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="REPLACE_WITH_S3_ACCESS_KEY"
# S3_SECRET_KEY="REPLACE_WITH_S3_SECRET_KEY"