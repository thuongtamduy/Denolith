{
  "info": {
    "name": "Denolith Role & Permission Management (RBAC+ABAC)",
    "description": "Bộ sưu tập API chuẩn dùng để test toàn bộ chức năng quản lý Role, Profile, và Override cho dự án Denolith.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9999",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PASTE_YOUR_OWNER_OR_ADMIN_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "uuid-cua-user",
      "type": "string"
    },
    {
      "key": "profileId",
      "value": "uuid-cua-profile",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Quản Lý Roles (RBAC)",
      "item": [
        {
          "name": "Lấy danh sách Roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/roles?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "roles"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Xem chi tiết Role",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/roles/sales_manager",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "roles",
                "sales_manager"
              ]
            }
          }
        },
        {
          "name": "Tạo mới Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"code\": \"sales_manager\",\n    \"tier\": \"admin\",\n    \"name\": \"Trưởng Phòng Sale\",\n    \"description\": \"Quản lý đội ngũ Sale\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "roles"
              ]
            }
          }
        },
        {
          "name": "Cập nhật Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Trưởng Phòng Kinh Doanh\",\n    \"description\": \"Updated\",\n    \"active\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/roles/sales_manager",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "roles",
                "sales_manager"
              ]
            }
          }
        },
        {
          "name": "Xóa Role",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/roles/sales_manager",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "roles",
                "sales_manager"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Gán Role Cho User",
      "item": [
        {
          "name": "Đổi Role của User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"role\": \"sales_manager\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}",
                "role"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Quản Lý Permission Profiles (ABAC)",
      "item": [
        {
          "name": "Danh sách các mã quyền (Atomic Codes)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/codes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "codes"
              ]
            }
          }
        },
        {
          "name": "Lấy danh sách Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/profiles?tier=admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "profiles"
              ],
              "query": [
                {
                  "key": "tier",
                  "value": "admin"
                }
              ]
            }
          }
        },
        {
          "name": "Tạo mới Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Bộ quyền Test\",\n    \"tier\": \"admin\",\n    \"description\": \"Demo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/permissions/profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "profiles"
              ]
            }
          }
        },
        {
          "name": "Xem chi tiết Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/profiles/{{profileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "profiles",
                "{{profileId}}"
              ]
            }
          }
        },
        {
          "name": "Sửa/Cấp quyền vào Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"granted\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/permissions/profiles/{{profileId}}/codes/users.read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "profiles",
                "{{profileId}}",
                "codes",
                "users.read"
              ]
            }
          }
        },
        {
          "name": "Gỡ bỏ quyền khỏi Profile",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/profiles/{{profileId}}/codes/users.read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "profiles",
                "{{profileId}}",
                "codes",
                "users.read"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Gán Phân Quyền Cá Nhân (Assignments)",
      "item": [
        {
          "name": "Danh sách Profiles của User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "profiles"
              ]
            }
          }
        },
        {
          "name": "Gán Profile cho User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"profileId\": \"{{profileId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "profiles"
              ]
            }
          }
        },
        {
          "name": "Thu hồi Profile khỏi User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/profiles/{{profileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "profiles",
                "{{profileId}}"
              ]
            }
          }
        },
        {
          "name": "Danh sách Overrides của User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/overrides",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "overrides"
              ]
            }
          }
        },
        {
          "name": "Set Override cho User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"granted\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/overrides/reports.export",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "overrides",
                "reports.export"
              ]
            }
          }
        },
        {
          "name": "Gỡ bỏ Override khỏi User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/permissions/users/{{userId}}/overrides/reports.export",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "permissions",
                "users",
                "{{userId}}",
                "overrides",
                "reports.export"
              ]
            }
          }
        }
      ]
    }
  ]
}
