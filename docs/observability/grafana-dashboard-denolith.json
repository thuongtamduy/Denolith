{
  "title": "Denolith API Baseline",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "RPS (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(denolith_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx Error Rate %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(denolith_http_errors_total{error_class=\"5xx\"}[5m])) / clamp_min(sum(rate(denolith_http_requests_total[5m])), 0.001)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "4xx Error Rate %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(denolith_http_errors_total{error_class=\"4xx\"}[5m])) / clamp_min(sum(rate(denolith_http_requests_total[5m])), 0.001)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(denolith_http_request_duration_ms_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(denolith_http_requests_total[5m])) by (status)",
          "legendFormat": "status {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(denolith_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(denolith_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(denolith_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Class (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "100 * sum(rate(denolith_http_errors_total{error_class=\"4xx\"}[5m])) / clamp_min(sum(rate(denolith_http_requests_total[5m])), 0.001)",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(denolith_http_errors_total{error_class=\"5xx\"}[5m])) / clamp_min(sum(rate(denolith_http_requests_total[5m])), 0.001)",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top Routes by Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(denolith_http_requests_total[5m])) by (route, method))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    }
  ]
}
